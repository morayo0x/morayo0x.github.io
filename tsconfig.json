{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@utils/*": ["./src/utils/*"],
      "@styles/*": ["./src/styles/*"]
    },
    "strictNullChecks": true,
    "allowImportingTsExtensions": true
  },
  "mdx": {
    "plugins": [["remark-frontmatter", ["toml", "yaml"]], "remark-gfm", "remark-math"]
  }
}
