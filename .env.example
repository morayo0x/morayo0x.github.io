# .env.example
# Copy this to .env.local for local overrides.
# None of these are required — the site builds fine without them.
# .env.local is gitignored.

# Your public site URL (also set in astro.config.mjs)
PUBLIC_SITE_URL=https://yourusername.github.io

# Umami analytics (set in BaseHead.astro instead for simplicity)
# PUBLIC_UMAMI_WEBSITE_ID=your-website-id
# PUBLIC_UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js

# Giscus comments (if you add the component later)
# PUBLIC_GISCUS_REPO=yourusername/your-repo
# PUBLIC_GISCUS_REPO_ID=R_...
# PUBLIC_GISCUS_CATEGORY_ID=DIC_...
