---
// src/pages/writing/tags/[tag]/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/blog/PostCard.astro';
import { getAllTags } from '@utils/content';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map(({ tag }) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;

const allPosts = await getCollection('writing', ({ data }) =>
  !data.draft && data.tags.includes(tag)
);

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title={`#${tag}`}
  description={`All posts tagged with #${tag}.`}
>
  <div class="tag-page">
    <div class="container">

      <header class="page-header">
        <div class="breadcrumb">
          <a href="/writing/" class="crumb-link">Writing</a>
          <span aria-hidden="true">/</span>
          <span class="crumb-current">#{tag}</span>
        </div>
        <h1 class="page-title">
          <span class="tag-hash">#</span>{tag}
        </h1>
        <p class="post-count">
          {posts.length} {posts.length === 1 ? 'post' : 'posts'}
        </p>
      </header>

      <div class="post-list">
        {posts.map(post => <PostCard post={post} showCategory={true} />)}
      </div>

      {posts.length === 0 && (
        <p class="empty">No posts with this tag yet.</p>
      )}

      <div class="back-nav">
        <a href="/writing/" class="back-link">← All writing</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .tag-page { padding-bottom: 5rem; }

  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
    margin-bottom: 1.25rem;
  }

  .crumb-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .crumb-link:hover { color: var(--color-accent); }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .tag-hash {
    color: var(--color-accent);
  }

  .post-count {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
    margin: 0;
  }

  .post-list { display: flex; flex-direction: column; }

  .empty {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-subtle);
    text-align: center;
    padding: 4rem 0;
  }

  .back-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover { color: var(--color-accent); }
</style>
