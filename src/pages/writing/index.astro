---
// src/pages/writing/index.astro
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/blog/PostCard.astro';
import { getAllWriting, getAllTags, getWritingByCategory, formatDate } from '@utils/content';

const posts = await getAllWriting();
const tags = await getAllTags();
const reflections = await getWritingByCategory('reflections');
const projects = await getWritingByCategory('projects');

const categories = [
  {
    slug: 'reflections',
    label: 'Reflections',
    icon: '◈',
    posts: reflections,
    desc: 'personal essays, observations, and ideas.',
  },
  {
    slug: 'projects',
    label: 'Projects',
    icon: '◉',
    posts: projects,
    desc: 'technical writing, research and deep dives.',
  },
];
---

<BaseLayout
  title="Writing"
  description="All writing — reflections, research notes, and project logs."
>
  <div class="page-wrap">
    <!-- Header -->
    <header class="page-header">
      <h1 class="page-title">Writing</h1>
      <p class="page-desc">{posts.length} posts across two categories.</p>
    </header>

    <!-- 3-column category layout -->
    <div class="categories-grid">
      {
        categories.map(({ slug, label, posts: catPosts, desc }) => (
          <section class="cat-col" aria-labelledby={`cat-${slug}`}>
            <div class="cat-header">
              <div class="cat-header-row">
                {/* <span class="cat-icon" aria-hidden="true"> */}
                {/* {icon} */}
                {/* </span> */}
                <h2 id={`cat-${slug}`} class="cat-title">
                  <a href={`/writing/${slug}/`} class="cat-title-link">
                    {label}
                  </a>
                </h2>
                <span class="cat-count">{catPosts.length}</span>
              </div>
              <p class="cat-desc">{desc}</p>
            </div>

            <div class="cat-posts">
              {catPosts.length > 0 ? (
                catPosts.map((post) => (
                  <a href={`/writing/${post.id}/`} class="cat-post-card">
                    <h3 class="cat-post-title">{post.data.title}</h3>
                    <p class="cat-post-desc">{post.data.description}</p>
                    <div class="cat-post-meta">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate, 'short')}
                      </time>
                      {post.data.minutesRead && (
                        <>
                          <span aria-hidden="true">·</span>
                          <span>{post.data.minutesRead}</span>
                        </>
                      )}
                    </div>
                  </a>
                ))
              ) : (
                <p class="cat-empty">Nothing here yet.</p>
              )}
            </div>

            {catPosts.length > 0 && (
              <a href={`/writing/${slug}/`} class="cat-see-all">
                All {label} →
              </a>
            )}
          </section>
        ))
      }
    </div>

    <!-- Topics + Feeds -->
    <aside class="writing-meta">
      <div class="meta-section">
        <p class="meta-label">Topics</p>
        <div class="meta-tags">
          {
            tags.slice(0, 30).map(({ tag }) => (
              <a href={`/writing/tags/${tag}/`} class="tag">
                #{tag}
              </a>
            ))
          }
        </div>
      </div>
      <!-- <div class="meta-section">
        <p class="meta-label">Feeds</p>
        <div class="meta-feeds">
          <a href="/rss.xml" class="feed-link">RSS Feed</a>
          <a href="/feed.json" class="feed-link">JSON Feed</a>
        </div>
      </div> -->
    </aside>
  </div>
</BaseLayout>

<style>
  /* ── Single centered column — same pattern as PostLayout ── */
  .page-wrap {
    width: 100%;
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    padding: 0 1.5rem 5rem;
    box-sizing: border-box;
  }

  @media (min-width: 640px) {
    .page-wrap {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  /* ── Header ── */
  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin: 0 0 0.375rem;
  }

  .page-desc {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 1rem;
    margin: 0;
  }

  /* ── 2-column grid ── */
  .categories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (min-width: 1100px) {
    .categories-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  /* ── Category column ── */
  .cat-col {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .cat-header {
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: 0;
  }

  .cat-header-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }

  .cat-icon {
    color: var(--color-accent);
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .cat-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin: 0;
    flex: 1;
    /* no underline */
    border: none;
    text-decoration: none;
  }

  .cat-title-link {
    color: inherit;
    text-decoration: none;
    border: none;
    transition: color var(--transition-fast);
  }
  .cat-title-link:hover {
    color: var(--color-accent);
  }

  .cat-count {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-faint);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.1rem 0.45rem;
  }

  .cat-desc {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-text-subtle);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Post cards inside column ── */
  .cat-posts {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .cat-post-card {
    display: block;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
  }

  .cat-post-card:hover .cat-post-title {
    color: var(--color-accent);
  }

  .cat-post-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.35;
    margin: 0 0 0.3rem;
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
    /* no underline */
    border: none;
    text-decoration: none;
  }

  .cat-post-desc {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cat-post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    margin-bottom: 0.4rem;
  }

  .cat-post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .cat-tag {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    color: var(--color-text-faint);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
  }

  .cat-empty {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-subtle);
    font-size: 0.875rem;
    padding: 1rem 0;
  }

  .cat-see-all {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .cat-see-all:hover {
    color: var(--color-accent-hover);
  }

  /* ── Topics + Feeds ── */
  .writing-meta {
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .meta-section {
    flex: 1;
    min-width: 12rem;
  }

  .meta-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 0.75rem;
  }

  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .meta-feeds {
    display: flex;
    gap: 1.5rem;
  }

  .feed-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .feed-link:hover {
    color: var(--color-accent);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .page-title {
      font-size: 2rem;
    }
    .categories-grid {
      gap: 2.5rem;
    }
    .writing-meta {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
</style>
