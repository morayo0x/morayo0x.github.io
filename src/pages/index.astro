---
// src/pages/index.astro
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/blog/PostCard.astro';
import { getRecentWriting, getFeaturedWriting, formatDate } from '@utils/content';

const recent = await getRecentWriting(6);
const featured = await getFeaturedWriting(1);
const hero = featured[0] ?? recent[0];
---

<BaseLayout
  title="Home"
  description="Personal site of usman kolawole — writing on machine learning, reflections on life, and technical projects in maths, computer science, machine learning."
>
  <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">Hello, I'm</p>
        <h1 class="hero-name">Usman<span class="hero-dot">.</span></h1>e

        <p class="hero-bio">
          This blog is where I collect thoughts, questions, and lessons encountered along the way.
        </p>
        <p class="hero-bio">
          I write to preserve fragments of experience before they dissolve&mdash;as ink on paper and
          pixels on glowing screens.
        </p>

        <div class="hero-social">
          <a
            href="https://github.com/yourusername"
            target="_blank"
            rel="noopener"
            class="hero-social-link"
            aria-label="GitHub"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
          <a
            href="https://x.com/morayo0x"
            target="_blank"
            rel="noopener"
            class="hero-social-link"
            aria-label="X (Twitter)"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 1200 1227"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"
              ></path>
            </svg>
          </a>
        </div>

        <div class="hero-actions">
          <a href="/writing/" class="btn btn-primary">Read writing</a>
          <a href="/about/" class="btn btn-ghost">About me →</a>
        </div>
      </div>

      {
        hero && (
          <div class="hero-featured">
            <p class="hero-featured-label">Latest note</p>
            <a href={`/writing/${hero.id.replace(/\.md$/, '')}/`} class="hero-card">
              <span class={`category-badge category-${hero.data.category}`}>
                {hero.data.category}
              </span>
              <h2 class="hero-card-title">{hero.data.title}</h2>
              <p class="hero-card-desc">{hero.data.description}</p>
              <span class="hero-card-date">{formatDate(hero.data.pubDate, 'short')}</span>
            </a>
          </div>
        )
      }
    </div>
  </section>

  <!-- ─── Categories ────────────────────────────────────────────────────── -->
  <section class="categories-section">
    <div class="container">
      <div class="categories-grid">
        <a href="/writing/reflections/" class="category-card category-card-reflections">
          <h2 class="category-card-title">Reflections</h2>
          <p class="category-card-desc">personal essays; from the past, present and future.</p>
        </a>

        <a href="/writing/projects/" class="category-card category-card-projects">
          <h2 class="category-card-title">Projects</h2>
          <p class="category-card-desc">technical writing, and deep explorations.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── recent writing ────────────────────────────────────────────────── -->
  <section class="recent-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Recent writing</h2>
        <a href="/writing/" class="section-more">All notes →</a>
      </div>

      <div class="post-list">
        {recent.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .hero-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }

  .hero-dot {
    color: var(--color-accent);
  }

  .hero-bio {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
    max-width: 42ch;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.6rem 1.25rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    box-shadow: var(--shadow-md);
  }

  .btn-ghost {
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-strong);
    background: transparent;
  }

  .btn-ghost:hover {
    color: var(--color-text);
    background: var(--color-bg-elevated);
  }

  /* Hero card */
  .hero-featured-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 0.75rem;
  }

  .hero-card {
    display: block;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.75rem;
    text-decoration: none;
    transition:
      box-shadow var(--transition-base),
      border-color var(--transition-fast);
  }

  .hero-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
  }

  .hero-card .category-badge {
    margin-bottom: 0.75rem;
    display: inline-flex;
  }

  .hero-card-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0 0 0.625rem;
    letter-spacing: -0.02em;
  }

  .hero-card-desc {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .hero-card-date {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
  }

  .hero-social {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hero-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .hero-social-link:hover {
    color: var(--color-text);
  }

  /* ── Categories ── */
  .categories-section {
    padding: 4rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
  }

  .category-card {
    display: block;
    padding: 1.75rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition:
      box-shadow var(--transition-base),
      transform var(--transition-base);
    background: var(--color-bg);
  }

  .category-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .category-card-icon {
    display: block;
    font-size: 1.45rem;
    margin-bottom: 0.75rem;
    color: var(--color-accent);
  }

  .category-card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .category-card-desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Recent ── */
  .recent-section {
    padding: 4rem 0;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0;
  }

  .section-more {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .section-more:hover {
    color: var(--color-accent-hover);
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }
</style>
