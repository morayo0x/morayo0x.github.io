---
// src/layouts/PostLayout.astro
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '@components/blog/TableOfContents.astro';
import TagList from '@components/blog/TagList.astro';
import PostCard from '@components/blog/PostCard.astro';
import { formatDate } from '@utils/content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'writing'>;
  headings: { depth: number; slug: string; text: string }[];
  related?: CollectionEntry<'writing'>[];
}

const { post, headings, related = [] } = Astro.props;
const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags,
  minutesRead,
  math,
  toc,
  // authors,
  // doi,
  // arxiv,
  series,
  seriesOrder,
  coverImage,
  coverAlt,
  ogImage,
} = post.data;

const categoryLabel = { reflections: 'rRflections', projects: 'Projects' }[category];
const hasToc = toc && headings.filter((h) => h.depth <= 3).length > 2;
// const isResearch = category === 'research';
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  math={math}
  pubDate={pubDate}
  updatedDate={updatedDate}
  image={ogImage}
>
  <!-- Single centered column wrapper for EVERYTHING -->
  <div class="page-wrap">
    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <header class="post-header">
      <div class="post-header-meta">
        <a href={`/writing/${category}/`} class={`category-badge category-${category}`}>
          {categoryLabel}
        </a>
        {
          series && (
            <span class="series-label">
              {series}
              {seriesOrder ? ` · Part ${seriesOrder}` : ''}
            </span>
          )
        }
      </div>

      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>

      <div class="post-byline">
        <div class="byline-left">
          <!-- <span class="byline-author">{authors?.join(', ') ?? 'Your Name'}</span> -->
          <!-- <span class="byline-sep" aria-hidden="true">·</span> -->
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {
            updatedDate && (
              <>
                <span class="byline-sep" aria-hidden="true">
                  ·
                </span>
                <span class="byline-updated">
                  Updated{' '}
                  <time datetime={updatedDate.toISOString()}>
                    {formatDate(updatedDate, 'short')}
                  </time>
                </span>
              </>
            )
          }
        </div>
        {
          minutesRead && (
            <span class="byline-rt">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <>
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </>
              </svg>
              {minutesRead}
            </span>
          )
        }
      </div>

      <!-- {
        isResearch && (doi || arxiv) && (
          <div class="research-links">
            {doi && (
              <a
                href={`https://doi.org/${doi}`}
                target="_blank"
                rel="noopener"
                class="research-link"
              >
                DOI: {doi}
              </a>
            )}
            {arxiv && (
              <a
                href={`https://arxiv.org/abs/${arxiv}`}
                target="_blank"
                rel="noopener"
                class="research-link"
              >
                arXiv: {arxiv}
              </a>
            )}
          </div>
        )
      } -->

      {
        coverImage && (
          <div class="post-cover">
            <img src={coverImage} alt={coverAlt ?? title} loading="eager" decoding="async" />
          </div>
        )
      }
    </header>

    <!-- ── TOC (inline, above content, visible on medium screens) ─────── -->
    {
      hasToc && (
        <nav class="toc-inline" aria-label="Table of contents">
          <p class="toc-inline-label">Contents</p>
          <TableOfContents headings={headings} />
        </nav>
      )
    }

    <!-- ── Article content ────────────────────────────────────────────── -->
    <article class="post-article">
      <slot />
    </article>

    <!-- ── Footer ─────────────────────────────────────────────────────── -->
    <footer class="post-footer">
      {
        tags.length > 0 && (
          <div class="post-tags">
            <TagList tags={tags} />
          </div>
        )
      }
      <div class="post-footer-nav">
        <a href="/writing/" class="back-link">← All writing</a>
        {
          updatedDate && (
            <p class="last-updated">
              Updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
            </p>
          )
        }
      </div>
      {
        related.length > 0 && (
          <section aria-labelledby="related-heading">
            <h2 id="related-heading" class="related-heading">
              Related
            </h2>
            <div class="related-grid">
              {related.map((p) => (
                <PostCard post={p} compact />
              ))}
            </div>
          </section>
        )
      }
    </footer>
  </div><!-- /page-wrap -->

  <!-- ── TOC floating sidebar (large screens only, via CSS) ─────────── -->
  {
    hasToc && (
      <aside class="toc-sidebar" aria-label="Table of contents" aria-hidden="true">
        <p class="toc-sidebar-label">Contents</p>
        <TableOfContents headings={headings} />
      </aside>
    )
  }
</BaseLayout>

<style>
  /* ── The single centered column ─────────────────────────────────────────
     Everything lives inside .page-wrap.
     max-width + auto margins = centered on all screen sizes.
  ── */
  .page-wrap {
    width: 100%;
    max-width: 52rem;
    margin-left: auto;
    margin-right: auto;
    padding: 0 1.5rem 5rem;
    box-sizing: border-box;
  }

  @media (min-width: 640px) {
    .page-wrap {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  /* ── Header ── */
  .post-header {
    padding-top: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .post-header-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .series-label {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .post-description {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }

  .post-byline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-subtle);
  }

  .byline-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .byline-author {
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .byline-sep {
    color: var(--color-text-faint);
  }
  .byline-updated {
    font-style: italic;
  }

  .byline-rt {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .research-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .research-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid var(--color-accent-light);
    padding: 0.2rem 0.6rem;
    border-radius: 0.25rem;
    background: var(--color-accent-subtle);
  }

  .post-cover {
    margin-top: 2rem;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .post-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Inline TOC (medium screens, inside the column) ── */
  .toc-inline {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }

  /* Hide inline TOC on large screens where sidebar TOC shows */
  @media (min-width: 1200px) {
    .toc-inline {
      display: none;
    }
  }

  .toc-inline-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 0.75rem;
  }

  /* ── Article prose ── */
  .post-article {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* Headings */
  .post-article :global(h2) {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 3rem 0 1rem;
  }

  .post-article :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin: 2.5rem 0 0.75rem;
  }

  .post-article :global(h4) {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 2rem 0 0.5rem;
  }

  /* Paragraphs */
  .post-article :global(p) {
    margin: 0 0 1.5rem;
  }

  /* Links */
  .post-article :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    text-underline-offset: 3px;
    font-weight: 500;
    transition:
      color 120ms,
      text-decoration-color 120ms;
  }
  .post-article :global(a:hover) {
    color: var(--color-accent-hover);
    text-decoration-color: var(--color-accent);
  }

  /* Strong / em */
  .post-article :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }
  .post-article :global(em) {
    font-style: italic;
  }

  /* Blockquote */
  .post-article :global(blockquote) {
    border-left: 3px solid var(--color-accent-light);
    padding: 0.25rem 0 0.25rem 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-text-muted);
  }
  .post-article :global(blockquote p) {
    margin: 0;
  }

  /* Inline code */
  .post-article :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }
  .post-article :global(code::before),
  .post-article :global(code::after) {
    content: none;
  }

  /* Code blocks */
  .post-article :global(pre) {
    margin: 2rem 0;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.7;
  }
  .post-article :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  /* Lists */
  .post-article :global(ul),
  .post-article :global(ol) {
    margin: 0 0 1.5rem 1.5rem;
    padding: 0;
  }
  .post-article :global(li) {
    margin-bottom: 0.4rem;
  }

  /* Tables */
  .post-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    margin: 2rem 0;
    overflow-x: auto;
    display: block;
  }
  .post-article :global(th) {
    font-weight: 600;
    text-align: left;
    padding: 0.625rem 1rem;
    border-bottom: 2px solid var(--color-border-strong);
    white-space: nowrap;
  }
  .post-article :global(td) {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .post-article :global(tr:last-child td) {
    border-bottom: none;
  }

  /* HR */
  .post-article :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  /* Images */
  .post-article :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    margin: 2rem auto;
    display: block;
  }

  /* ── Footer ── */
  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .post-tags {
    margin-bottom: 1.5rem;
  }

  .post-footer-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 120ms;
  }
  .back-link:hover {
    color: var(--color-accent);
  }

  .last-updated {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
    font-style: italic;
    margin: 0;
  }

  .related-heading {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 1.5rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 1rem;
  }

  /* ── Floating TOC sidebar (large screens only) ──────────────────────────
     Positioned absolutely relative to the viewport so it doesn't affect
     the centered column layout at all.
  ── */
  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1200px) {
    .toc-sidebar {
      display: block;
      position: fixed;
      top: 6rem;
      /* Sits to the right of the 52rem centered column */
      left: calc(50% + 26rem + 2rem);
      width: 13rem;
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
    }
  }

  .toc-sidebar-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 0.75rem;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .post-title {
      font-size: 1.75rem;
    }
    .post-article {
      font-size: 1rem;
      line-height: 1.75;
    }
    .post-article :global(h2) {
      font-size: 1.375rem;
      margin-top: 2.5rem;
    }
    .post-article :global(h3) {
      font-size: 1.125rem;
      margin-top: 2rem;
    }
  }
</style>

<!-- TOC active highlighting -->
<script>
  const tocLinks = document.querySelectorAll('.toc-inline a, .toc-sidebar a');
  const headings = document.querySelectorAll('.post-article h2, .post-article h3');

  if (tocLinks.length && headings.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            tocLinks.forEach((link) => {
              link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
            });
          }
        }
      },
      { rootMargin: '-10% 0% -80% 0%', threshold: 0 }
    );
    headings.forEach((h) => observer.observe(h));
  }
</script>
