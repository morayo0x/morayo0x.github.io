---
// src/layouts/ProjectLayout.astro
// Project posts get the same PostLayout but with added metadata sidebar
// (tech stack, links, status, dates).

import PostLayout from './PostLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'writing'>;
  headings: { depth: number; slug: string; text: string }[];
  related?: CollectionEntry<'writing'>[];
  // Project-specific extras (passed from MDX frontmatter or page)
  stack?: string[];
  status?: 'active' | 'complete' | 'archived' | 'paused';
  repo?: string;
  demo?: string;
}

const { post, headings, related, stack, status, repo, demo } = Astro.props;

const statusLabel = {
  active:   { label: 'Active',    color: '#22c55e' },
  complete: { label: 'Complete',  color: '#60a5fa' },
  archived: { label: 'Archived',  color: '#94a3b8' },
  paused:   { label: 'Paused',    color: '#f59e0b' },
}[status ?? 'active'];
---

<PostLayout post={post} headings={headings} related={related}>
  <!-- Project meta bar inserted before content -->
  {(stack || status || repo || demo) && (
    <div class="project-meta-bar" slot="before-content">
      {status && (
        <div class="project-meta-item">
          <span class="meta-label">Status</span>
          <span class="meta-status" style={`color: ${statusLabel.color}`}>
            <span class="status-dot" style={`background: ${statusLabel.color}`} aria-hidden="true"></span>
            {statusLabel.label}
          </span>
        </div>
      )}

      {stack && stack.length > 0 && (
        <div class="project-meta-item">
          <span class="meta-label">Stack</span>
          <span class="meta-stack">{stack.join(' · ')}</span>
        </div>
      )}

      {(repo || demo) && (
        <div class="project-meta-item project-meta-links">
          {repo && (
            <a href={repo} target="_blank" rel="noopener" class="project-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Source
            </a>
          )}
          {demo && (
            <a href={demo} target="_blank" rel="noopener" class="project-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Live demo
            </a>
          )}
        </div>
      )}
    </div>
  )}

  <slot />
</PostLayout>

<style>
  .project-meta-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 2.5rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .project-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .meta-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .meta-status {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .meta-stack {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .project-meta-links {
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid var(--color-accent-light);
    padding: 0.25rem 0.625rem;
    border-radius: 0.3rem;
    background: var(--color-accent-subtle);
    transition: background var(--transition-fast);
  }

  .project-link:hover {
    background: var(--color-accent-light);
  }
</style>
