---
// src/layouts/ResearchLayout.astro
// Extended layout for research posts — adds abstract box, citation info, series nav
import PostLayout from './PostLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'writing'>;
  headings: { depth: number; slug: string; text: string }[];
  related?: CollectionEntry<'writing'>[];
  abstract?: string;
}

const { post, headings, related, abstract } = Astro.props;
---

<PostLayout post={post} headings={headings} related={related}>
  <!-- Abstract block — injected before content slot -->
  {abstract && (
    <div class="abstract-block" slot="before-content">
      <p class="abstract-label">Abstract</p>
      <p class="abstract-text">{abstract}</p>
    </div>
  )}

  <slot />
</PostLayout>

<style>
  .abstract-block {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
    background: var(--color-bg-elevated);
  }

  .abstract-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 0.625rem;
  }

  .abstract-text {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
    font-style: italic;
  }
</style>
