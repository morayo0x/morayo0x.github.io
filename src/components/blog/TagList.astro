---
// src/components/blog/TagList.astro
interface Props {
  tags: string[];
  linked?: boolean;
}

const { tags, linked = true } = Astro.props;
---

<ul class="tag-list" role="list" aria-label="Tags">
  {tags.map(tag => (
    <li>
      {linked
        ? <a href={`/writing/tags/${tag}/`} class="tag">#{tag}</a>
        : <span class="tag">#{tag}</span>
      }
    </li>
  ))}
</ul>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
