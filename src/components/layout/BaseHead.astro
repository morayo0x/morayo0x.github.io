---
// src/components/layout/BaseHead.astro
// Central <head> manager — SEO, Open Graph, Twitter Cards, KaTeX, Umami

interface Props {
  title: string;
  description: string;
  image?: string;
  pubDate?: Date;
  updatedDate?: Date;
  type?: 'website' | 'article';
  math?: boolean;
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/og-default.png',
  pubDate,
  updatedDate,
  type = 'website',
  // math = false,
  canonicalURL: canonicalOverride,
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://yourusername.github.io');
const canonical = canonicalOverride
  ? new URL(canonicalOverride)
  : new URL(Astro.url.pathname, siteUrl);

const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).toString();
const fullTitle = title === 'Home' ? 'morayo' : `${title} — morayo`;

// Umami analytics — set your script URL and website ID
// Self-hosted: https://umami.is/docs/getting-started
// Cloud: https://cloud.umami.is
const UMAMI_SCRIPT = 'https://analytics.umami.is/script.js';
const UMAMI_WEBSITE_ID = 'YOUR-WEBSITE-ID'; // Replace with your Umami website ID
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- ─── Favicon ─────────────────────────────────────────────────────────── -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#338480" />

<!-- ─── SEO ─────────────────────────────────────────────────────────────── -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- ─── Open Graph ──────────────────────────────────────────────────────── -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content="Usman Kolawole" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />

<!-- ─── Twitter / X Cards ───────────────────────────────────────────────── -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@morayo0x" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- ─── article metadata ────────────────────────────────────────────────── -->
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
{type === 'article' && <meta property="article:author" content="Usman Kolawole" />}

<!-- ─── Feeds ────────────────────────────────────────────────────────────── -->
<link rel="alternate" type="application/rss+xml" title="Usman Kolawole — RSS" href="/rss.xml" />
<link
  rel="alternate"
  type="application/feed+json"
  title="Your Name — JSON Feed"
  href="/feed.json"
/>

<!-- ─── dark mode — anti-focus script (runs before paint) ────────────────── -->
<script is:inline>
  (function () {
    const stored = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = stored ?? (prefersDark ? 'dark' : 'light');
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    }
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>

<!-- ─── JSON-LD Structured Data ─────────────────────────────────────────── -->
{
  type === 'article' && pubDate && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description: description,
        image: ogImage,
        datePublished: pubDate.toISOString(),
        dateModified: (updatedDate ?? pubDate).toISOString(),
        author: {
          '@type': 'Person',
          name: 'Usman Kolawole',
          url: siteUrl.toString(),
        },
        publisher: {
          '@type': 'Person',
          name: 'Usman Kolawole',
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': canonical.toString(),
        },
      })}
    />
  )
}

{
  type === 'website' && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Usman Kolawole',
        url: siteUrl.toString(),
        description: 'Personal site — writing, research, and projects',
        potentialAction: {
          '@type': 'SearchAction',
          target: `${siteUrl}search/?q={search_term_string}`,
          'query-input': 'required name=search_term_string',
        },
      })}
    />
  )
}

<!-- ─── Umami Analytics (privacy-first, no cookies) ─────────────────────── -->
<!-- Only loads in production. Replace UMAMI_WEBSITE_ID above. -->
{
  import.meta.env.PROD && UMAMI_WEBSITE_ID !== 'YOUR-WEBSITE-ID' && (
    <script defer src={UMAMI_SCRIPT} data-website-id={UMAMI_WEBSITE_ID} is:inline />
  )
}
