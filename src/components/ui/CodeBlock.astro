---
// src/components/ui/CodeBlock.astro
// Wraps a code block with an optional filename label + copy-to-clipboard button
// Usage in MDX:
//   <CodeBlock filename="astro.config.mjs" lang="js">
//     {`your code here`}
//   </CodeBlock>

interface Props {
  filename?: string;
  lang?: string;
}

const { filename, lang } = Astro.props;
---

<div class="code-block-wrapper">
  {filename && (
    <div class="code-block-header">
      <span class="code-filename">{filename}</span>
      {lang && <span class="code-lang">{lang}</span>}
      <button class="copy-btn" aria-label="Copy code" title="Copy to clipboard">
        <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
        <svg class="check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </button>
    </div>
  )}

  <div class="code-block-content">
    <slot />
  </div>

  {!filename && (
    <button class="copy-btn copy-btn-floating" aria-label="Copy code" title="Copy to clipboard">
      <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      <svg class="check-icon hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5"/>
      </svg>
    </button>
  )}
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const wrapper = btn.closest('.code-block-wrapper');
      const pre = wrapper?.querySelector('pre');
      const text = pre?.textContent ?? '';

      try {
        await navigator.clipboard.writeText(text);
        const copyIcon  = btn.querySelector('.copy-icon') as HTMLElement;
        const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        setTimeout(() => {
          copyIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
        }, 2000);
      } catch {
        console.warn('Copy failed');
      }
    });
  });
</script>

<style>
  .code-block-wrapper {
    position: relative;
    margin: 1.75rem 0;
  }

  .code-block-wrapper:hover .copy-btn-floating {
    opacity: 1;
  }

  .code-block-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-bottom: none;
    padding: 0.375rem 0.875rem;
    border-radius: 0.5rem 0.5rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .code-filename {
    color: var(--color-text-muted);
    flex: 1;
  }

  .code-lang {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.6875rem;
  }

  .code-block-header + .code-block-content :global(pre) {
    margin-top: 0;
    border-radius: 0 0 0.5rem 0.5rem;
    border-top: none;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.3rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
    flex-shrink: 0;
  }

  .copy-btn:hover {
    background: var(--color-bg-sunken);
    color: var(--color-text);
  }

  .copy-btn-floating {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    opacity: 0;
    transition: opacity var(--transition-fast);
    background: var(--color-bg-elevated);
  }

  .hidden { display: none !important; }

  /* The check icon shows green on copy */
  .check-icon { color: #22c55e; }
</style>
