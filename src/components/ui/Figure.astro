---
// src/components/ui/Figure.astro
// Usage in MDX:
// <Figure src="/images/diagram.png" alt="System diagram" caption="Figure 1: Architecture overview" />

interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  fullWidth?: boolean;
}

const { src, alt, caption, width, height, fullWidth = false } = Astro.props;
---

<figure class={`content-figure ${fullWidth ? 'full-width' : ''}`}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    decoding="async"
  />
  {caption && (
    <figcaption>{caption}</figcaption>
  )}
</figure>

<style>
  .content-figure {
    margin: 2rem 0;
    text-align: center;
  }

  .content-figure img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    display: inline-block;
  }

  .full-width img {
    width: 100%;
  }

  figcaption {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
    margin-top: 0.625rem;
    font-style: italic;
    line-height: 1.5;
  }
</style>
